{
  "openapi": "3.0.3",
  "info": {
    "title": "MOSSIM API",
    "description": "REST API for the MOSSIM fashion e-commerce platform. Customer-facing endpoints are under /api/v1/. Protected routes require a JWT Bearer token obtained from /api/v1/auth/login.",
    "version": "1.0.0",
    "contact": {
      "name": "Minhaj Uddin Hassan",
      "email": "mdhassan49.muh@gmail.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost/MOSSIM/public/api/v1",
      "description": "Local XAMPP development"
    }
  ],
  "tags": [
    { "name": "Auth",      "description": "Customer registration, login, and token management" },
    { "name": "Products",  "description": "Browse the product catalogue" },
    { "name": "Orders",    "description": "Place and manage customer orders" },
    { "name": "Coupons",   "description": "Validate coupon codes" },
    { "name": "Reviews",   "description": "Submit and manage product reviews" },
    { "name": "Customer",  "description": "Customer profile and saved addresses" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token returned by /auth/login. Pass as: Authorization: Bearer {token}"
      }
    },
    "schemas": {
      "Currency": {
        "type": "object",
        "properties": {
          "id":            { "type": "string", "format": "uuid" },
          "code":          { "type": "string", "example": "BDT" },
          "symbol":        { "type": "string", "example": "৳" },
          "exchange_rate": { "type": "number", "example": 1.0 },
          "is_default":    { "type": "boolean" }
        }
      },
      "ProductColor": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "color_name": { "type": "string", "example": "Sky Blue" },
          "color_hex":  { "type": "string", "example": "#87CEEB", "nullable": true }
        }
      },
      "ProductSize": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "size_label": { "type": "string", "example": "M" },
          "sort_order": { "type": "integer", "example": 2 }
        }
      },
      "ProductPrice": {
        "type": "object",
        "properties": {
          "id":             { "type": "string", "format": "uuid" },
          "currency":       { "$ref": "#/components/schemas/Currency" },
          "actual_price":   { "type": "number", "example": 2200.00 },
          "discount_type":  { "type": "string", "enum": ["percent", "flat"], "nullable": true },
          "discount_value": { "type": "number", "example": 10 },
          "current_price":  { "type": "number", "example": 1980.00, "description": "MySQL generated column — actual price after discount" },
          "is_default":     { "type": "boolean" }
        }
      },
      "ProductVariantBrief": {
        "type": "object",
        "description": "Variant summary used in product listings",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "sku":        { "type": "string", "example": "MO1001-WH-M" },
          "color":      { "$ref": "#/components/schemas/ProductColor" },
          "size":       { "$ref": "#/components/schemas/ProductSize" },
          "stock_qty":  { "type": "integer", "example": 24 },
          "is_active":  { "type": "boolean" },
          "is_default": { "type": "boolean" },
          "default_price": { "$ref": "#/components/schemas/ProductPrice" }
        }
      },
      "ProductImage": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "url":        { "type": "string", "example": "/images/products/MO1001/white-front.jpg" },
          "alt_text":   { "type": "string", "nullable": true },
          "color_id":   { "type": "string", "format": "uuid", "nullable": true, "description": "null means image applies to all colors" },
          "is_primary": { "type": "boolean" },
          "sort_order": { "type": "integer" }
        }
      },
      "ProductList": {
        "type": "object",
        "description": "Lightweight product summary used in listing responses",
        "properties": {
          "id":           { "type": "string", "format": "uuid" },
          "product_code": { "type": "string", "example": "MO1001" },
          "name":         { "type": "string", "example": "Classic Oxford Shirt" },
          "type":         { "type": "string", "enum": ["man", "women", "kids", "unisex"] },
          "colors":       { "type": "array", "items": { "$ref": "#/components/schemas/ProductColor" } },
          "sizes":        { "type": "array", "items": { "$ref": "#/components/schemas/ProductSize" } },
          "primary_image": { "$ref": "#/components/schemas/ProductImage", "nullable": true },
          "default_variant": { "$ref": "#/components/schemas/ProductVariantBrief", "nullable": true }
        }
      },
      "ProductDetail": {
        "type": "object",
        "description": "Full product data returned by the show endpoint",
        "properties": {
          "id":           { "type": "string", "format": "uuid" },
          "product_code": { "type": "string", "example": "MO1001" },
          "name":         { "type": "string" },
          "type":         { "type": "string", "enum": ["man", "women", "kids", "unisex"] },
          "description":  { "type": "string" },
          "is_active":    { "type": "boolean" },
          "colors":       { "type": "array", "items": { "$ref": "#/components/schemas/ProductColor" } },
          "sizes":        { "type": "array", "items": { "$ref": "#/components/schemas/ProductSize" } },
          "images":       { "type": "array", "items": { "$ref": "#/components/schemas/ProductImage" } },
          "variants": {
            "type": "array",
            "items": {
              "allOf": [
                { "$ref": "#/components/schemas/ProductVariantBrief" },
                {
                  "type": "object",
                  "properties": {
                    "prices": { "type": "array", "items": { "$ref": "#/components/schemas/ProductPrice" } }
                  }
                }
              ]
            }
          },
          "average_rating": { "type": "number", "example": 4.3, "nullable": true },
          "review_count":   { "type": "integer", "example": 12 }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "name":       { "type": "string" },
          "email":      { "type": "string", "format": "email" },
          "phone":      { "type": "string", "nullable": true },
          "type":       { "type": "string", "enum": ["online", "walk_in"] },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CustomerAddress": {
        "type": "object",
        "properties": {
          "id":            { "type": "string", "format": "uuid" },
          "label":         { "type": "string", "example": "Home" },
          "address_line1": { "type": "string" },
          "city":          { "type": "string" },
          "country":       { "type": "string", "example": "BD" },
          "is_default":    { "type": "boolean" }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id":            { "type": "string", "format": "uuid" },
          "variant_id":    { "type": "string", "format": "uuid" },
          "sku":           { "type": "string" },
          "product_name":  { "type": "string" },
          "color":         { "type": "string" },
          "size":          { "type": "string" },
          "qty":           { "type": "integer" },
          "unit_price":    { "type": "number", "description": "Snapshot of price at purchase time" },
          "discount_pct":  { "type": "number", "description": "Snapshot of discount at purchase time" },
          "line_total":    { "type": "number" },
          "return_status": { "type": "string", "enum": ["none", "requested", "approved", "completed"] }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id":             { "type": "string", "format": "uuid" },
          "order_number":   { "type": "string", "example": "ORD-20260001" },
          "status":         { "type": "string", "enum": ["pending", "accepted", "rejected", "shipped", "delivered", "returned", "cancelled"] },
          "channel":        { "type": "string", "enum": ["online", "offline"] },
          "currency":       { "$ref": "#/components/schemas/Currency" },
          "subtotal":       { "type": "number" },
          "discount_amount":{ "type": "number" },
          "shipping_fee":   { "type": "number" },
          "total_amount":   { "type": "number" },
          "notes":          { "type": "string", "nullable": true },
          "placed_at":      { "type": "string", "format": "date-time" },
          "items":          { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "product_id":  { "type": "string", "format": "uuid" },
          "customer":    { "$ref": "#/components/schemas/Customer" },
          "rating":      { "type": "integer", "minimum": 1, "maximum": 5 },
          "title":       { "type": "string", "nullable": true },
          "body":        { "type": "string", "nullable": true },
          "status":      { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "images":      { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "sort_order": { "type": "integer" } } } },
          "created_at":  { "type": "string", "format": "date-time" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": { "type": "integer" },
          "last_page":    { "type": "integer" },
          "per_page":     { "type": "integer" },
          "total":        { "type": "integer" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data":    { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "errors":  { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
        }
      },
      "UnauthorizedResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "Unauthenticated." }
        }
      }
    }
  },
  "paths": {

    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new customer",
        "operationId": "authRegister",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "password_confirmation"],
                "properties": {
                  "name":                  { "type": "string", "example": "John Doe" },
                  "email":                 { "type": "string", "format": "email", "example": "john@example.com" },
                  "phone":                 { "type": "string", "example": "+8801712345678", "nullable": true },
                  "password":              { "type": "string", "minLength": 8, "example": "secret123" },
                  "password_confirmation": { "type": "string", "example": "secret123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Customer registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success":      { "type": "boolean", "example": true },
                    "access_token": { "type": "string" },
                    "token_type":   { "type": "string", "example": "bearer" },
                    "expires_in":   { "type": "integer", "example": 3600 },
                    "customer":     { "$ref": "#/components/schemas/Customer" }
                  }
                }
              }
            }
          },
          "422": { "description": "Validation failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login and obtain JWT",
        "operationId": "authLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email":    { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "example": "secret123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success":      { "type": "boolean", "example": true },
                    "access_token": { "type": "string" },
                    "token_type":   { "type": "string", "example": "bearer" },
                    "expires_in":   { "type": "integer", "example": 3600 },
                    "customer":     { "$ref": "#/components/schemas/Customer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Invalidate the current JWT",
        "operationId": "authLogout",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UnauthorizedResponse" } } } }
        }
      }
    },

    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh the JWT access token",
        "operationId": "authRefresh",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "New token issued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" },
                    "token_type":   { "type": "string", "example": "bearer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      }
    },

    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the authenticated customer",
        "operationId": "authMe",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current customer",
            "content": {
              "application/json": {
                "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Customer" } } }] }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      }
    },

    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List active products",
        "operationId": "productIndex",
        "description": "Public endpoint. Returns paginated active products with colors, sizes, primary image, and default variant with default BDT price.",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Search by product name or code" },
          { "name": "type",   "in": "query", "schema": { "type": "string", "enum": ["man", "women", "kids", "unisex"] }, "description": "Filter by product type" },
          { "name": "page",   "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated product list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "items": { "type": "array", "items": { "$ref": "#/components/schemas/ProductList" } },
                        "meta":  { "$ref": "#/components/schemas/PaginationMeta" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get full product detail",
        "operationId": "productShow",
        "description": "Public endpoint. Returns all images, all active variants with prices in every currency, and review statistics.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Product detail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data":    { "$ref": "#/components/schemas/ProductDetail" }
                  }
                }
              }
            }
          },
          "404": { "description": "Product not found or inactive" }
        }
      }
    },

    "/products/{id}/reviews": {
      "get": {
        "tags": ["Products", "Reviews"],
        "summary": "Get approved reviews for a product",
        "operationId": "productReviews",
        "description": "Public endpoint. Returns paginated approved reviews ordered by newest first.",
        "parameters": [
          { "name": "id",   "in": "path",  "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": {
            "description": "Approved reviews",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "items":          { "type": "array", "items": { "$ref": "#/components/schemas/Review" } },
                        "average_rating": { "type": "number" },
                        "meta":           { "$ref": "#/components/schemas/PaginationMeta" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Reviews"],
        "summary": "Submit a review for a product",
        "operationId": "reviewStore",
        "description": "JWT required. Customer must have a delivered order containing this product. One review per product per customer.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rating"],
                "properties": {
                  "rating":        { "type": "integer", "minimum": 1, "maximum": 5, "example": 5 },
                  "title":         { "type": "string", "maxLength": 120, "nullable": true },
                  "body":          { "type": "string", "nullable": true },
                  "order_item_id": { "type": "string", "format": "uuid", "nullable": true, "description": "Specific order item that triggered the review" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Review submitted (status: pending)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "403": { "description": "Customer has not purchased this product" },
          "422": { "description": "Validation failed" }
        }
      }
    },

    "/reviews/{id}": {
      "put": {
        "tags": ["Reviews"],
        "summary": "Edit own review (only if status is pending)",
        "operationId": "reviewUpdate",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "title":  { "type": "string", "maxLength": 120, "nullable": true },
                  "body":   { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Review updated" },
          "403": { "description": "Not your review, or already moderated" },
          "404": { "description": "Review not found" }
        }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "Delete own review",
        "operationId": "reviewDestroy",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Review deleted" },
          "403": { "description": "Not your review" },
          "404": { "description": "Review not found" }
        }
      }
    },

    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List the authenticated customer's orders",
        "operationId": "orderIndex",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "accepted", "rejected", "shipped", "delivered", "returned", "cancelled"] } },
          { "name": "page",   "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Order list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "items": { "type": "array", "items": { "$ref": "#/components/schemas/Order" } },
                        "meta":  { "$ref": "#/components/schemas/PaginationMeta" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Place a new online order",
        "operationId": "orderStore",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items", "currency_id"],
                "properties": {
                  "currency_id":         { "type": "string", "format": "uuid", "description": "Currency for this order" },
                  "shipping_address_id": { "type": "string", "format": "uuid", "nullable": true },
                  "coupon_code":         { "type": "string", "nullable": true, "example": "SAVE10" },
                  "notes":               { "type": "string", "nullable": true },
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["variant_id", "qty"],
                      "properties": {
                        "variant_id": { "type": "string", "format": "uuid" },
                        "qty":        { "type": "integer", "minimum": 1, "example": 2 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order placed successfully (status: pending)", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Order" } } } } } },
          "422": { "description": "Validation failed or insufficient stock" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },

    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order detail",
        "operationId": "orderShow",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Order with items, shipment, and payment", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Order" } } } } } },
          "403": { "description": "Not your order" },
          "404": { "description": "Order not found" }
        }
      }
    },

    "/orders/{id}/return": {
      "post": {
        "tags": ["Orders"],
        "summary": "Request a return on a delivered order item",
        "operationId": "orderReturn",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["order_item_id", "qty_returned", "reason"],
                "properties": {
                  "order_item_id": { "type": "string", "format": "uuid" },
                  "qty_returned":  { "type": "integer", "minimum": 1 },
                  "reason":        { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Return request submitted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "422": { "description": "Order not delivered or qty exceeds purchased" }
        }
      }
    },

    "/coupons/validate": {
      "post": {
        "tags": ["Coupons"],
        "summary": "Validate a coupon code",
        "operationId": "couponValidate",
        "description": "JWT required. Call this before placing an order to preview the discount.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code", "order_amount"],
                "properties": {
                  "code":         { "type": "string", "example": "SAVE10" },
                  "order_amount": { "type": "number", "example": 5000 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "object",
                      "properties": {
                        "code":           { "type": "string" },
                        "discount_type":  { "type": "string", "enum": ["pct", "flat"] },
                        "discount_value": { "type": "number" },
                        "discount_amount":{ "type": "number", "example": 500 },
                        "final_amount":   { "type": "number", "example": 4500 }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": { "description": "Invalid, expired, or minimum amount not met", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthenticated" }
        }
      }
    },

    "/customer/profile": {
      "get": {
        "tags": ["Customer"],
        "summary": "Get own profile",
        "operationId": "customerProfile",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Customer profile", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Customer" } } } } } },
          "401": { "description": "Unauthenticated" }
        }
      },
      "patch": {
        "tags": ["Customer"],
        "summary": "Update name or phone",
        "operationId": "customerProfileUpdate",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name":  { "type": "string", "maxLength": 100 },
                  "phone": { "type": "string", "maxLength": 20 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated" },
          "422": { "description": "Validation failed" }
        }
      }
    },

    "/customer/addresses": {
      "get": {
        "tags": ["Customer"],
        "summary": "List saved addresses",
        "operationId": "addressIndex",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Address list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data":    { "type": "array", "items": { "$ref": "#/components/schemas/CustomerAddress" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Customer"],
        "summary": "Add a new address",
        "operationId": "addressStore",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["label", "address_line1", "city", "country"],
                "properties": {
                  "label":         { "type": "string", "example": "Home" },
                  "address_line1": { "type": "string" },
                  "city":          { "type": "string" },
                  "country":       { "type": "string", "example": "BD" },
                  "is_default":    { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Address created" },
          "422": { "description": "Validation failed" }
        }
      }
    },

    "/customer/addresses/{id}": {
      "delete": {
        "tags": ["Customer"],
        "summary": "Remove a saved address",
        "operationId": "addressDestroy",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Address removed" },
          "403": { "description": "Not your address" },
          "404": { "description": "Address not found" }
        }
      }
    }

  }
}
